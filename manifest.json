{
  "manifest_version": 3,
  "name": "书签管家",
  "version": "1.0.0",
  "description": "书签管家（Bookmark Butler）提供快速搜索、智能整理与一键收藏能力，让常用书签管理更轻松。",
  "permissions": [
    "bookmarks",
    "activeTab",
    "storage",
    "scripting",
    "notifications"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_title": "书签管家",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "commands": {
    "_execute_action": {
      "description": "打开书签管家"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "fallback.html",
        "fallback.js",
        "src/styles/modal.css",
        "icons/icon16.png",
        "icons/icon48.png",
        "icons/icon128.png"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
